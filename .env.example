# ==========================================================================
# Strapi Backend Environment Variables
# ==========================================================================
# Copy this file to .env and fill in actual values.
# Generate secrets with: ./scripts/generate-secrets.sh
# NEVER commit .env to git.
# ==========================================================================

# ---- Server ----
HOST=0.0.0.0
PORT=1337
NODE_ENV=development
# Public URL of this Strapi instance (used for media URLs, webhooks, etc.)
PUBLIC_URL=http://localhost:1337

# ---- Secrets (MUST be rotated before production) ----
# Generate with: openssl rand -base64 32
APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=
ENCRYPTION_KEY=

# ---- Database ----
# Supported clients: sqlite (default), mysql, postgres
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# For mysql / postgres:
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=sfc
# DATABASE_USERNAME=sfc_user
# DATABASE_PASSWORD=
# DATABASE_SSL=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SCHEMA=public

# ---- Security ----
# Comma-separated list of allowed origins for CORS.
# Use exact origins only (no wildcards) for production.
CORS_ORIGINS=http://localhost:3000

# reCAPTCHA v3 secret (server-side verification of contact form)
# Get from https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
# Minimum score (0.0 = bot, 1.0 = human). 0.5 is a reasonable threshold.
RECAPTCHA_MIN_SCORE=0.5

# ---- Observability (optional but recommended in production) ----
# SENTRY_DSN=
# SENTRY_ENV=development
